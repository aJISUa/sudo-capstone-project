# cp .env.example .env 후 값 채우기
# 환경: dev | staging | prod   (prod 는 아래 JWT_SECRET 기본값이면 기동이 차단됨)
ENV=dev

DATABASE_URL=postgresql+psycopg://oncare:oncare@localhost:5432/oncare
# 앱 기동 시 create_all() 로 테이블 생성(개발 편의). 운영은 Alembic 사용 → false 권장.
AUTO_CREATE_TABLES=true

# 운영에서는 반드시 교체:  openssl rand -hex 32
JWT_SECRET=CHANGE_ME_run_openssl_rand_hex_32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
# AI (이후 STEP)
RECOGNIZER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest
COACH_LLM=gemini
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o
EMBEDDER=gemini
OPENAI_EMBED_MODEL=text-embedding-3-small
# 기타
CORS_ALLOW_ORIGINS=*
SEED_DEMO_DATA=true

# --- RAG (STEP 7) ---
# 임베딩 차원은 EMBEDDER 모델에 맞춤: Gemini gemini-embedding-001=768 · OpenAI text-embedding-3-small=1536
EMBED_DIM=768
CHUNK_WINDOW=5
CHUNK_OVERLAP=1
RETRIEVE_PERSONAL_K=3
RETRIEVE_PUBLIC_K=3

# --- LiteLLM 프록시 (OpenAI 호환, Virtual Key 하나로 claude 등 호출) ---
# 실제 LiteLLM 호스트 주소는 팀 내부 문서/시크릿으로 관리하세요(여기엔 자리표시자만).
LITELLM_BASE_URL=http://localhost:4000
LITELLM_API_KEY=여기에_Virtual_Key
LITELLM_CHAT_MODEL=
LITELLM_VISION_MODEL=
# 프록시에 임베딩 모델이 있으면 그 이름을, 없으면 비워두고 EMBEDDER=openai/gemini 사용
LITELLM_EMBED_MODEL=

# AI 엔진 선택:
#   식단 인식: RECOGNIZER=claude (LiteLLM) | gemini | yolo
#   코치 LLM:  COACH_LLM=litellm | openai | gemini
#   임베딩:    EMBEDDER=openai | gemini | litellm
