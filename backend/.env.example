# cp .env.example .env 후 값 채우기
DATABASE_URL=postgresql+psycopg://oncare:oncare@localhost:5432/oncare
JWT_SECRET=CHANGE_ME_run_openssl_rand_hex_32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
# AI (이후 STEP)
RECOGNIZER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
COACH_LLM=openai
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o
EMBEDDER=openai
OPENAI_EMBED_MODEL=text-embedding-3-small
# 기타
CORS_ALLOW_ORIGINS=*
SEED_DEMO_DATA=true

# --- RAG (STEP 7) ---
EMBED_DIM=1536
CHUNK_WINDOW=5
CHUNK_OVERLAP=1
RETRIEVE_PERSONAL_K=3
RETRIEVE_PUBLIC_K=3

# --- LiteLLM 프록시 (OpenAI 호환, Virtual Key 하나로 claude 등 호출) ---
LITELLM_BASE_URL=http://43.201.226.184:4000
LITELLM_API_KEY=여기에_Virtual_Key
LITELLM_CHAT_MODEL=claude-haiku-4-5-20251001
LITELLM_VISION_MODEL=claude-haiku-4-5-20251001
# 프록시에 임베딩 모델이 있으면 그 이름을, 없으면 비워두고 EMBEDDER=openai/gemini 사용
LITELLM_EMBED_MODEL=

# AI 엔진 선택:
#   식단 인식: RECOGNIZER=claude (LiteLLM) | gemini | yolo
#   코치 LLM:  COACH_LLM=litellm | openai | gemini
#   임베딩:    EMBEDDER=openai | gemini | litellm
